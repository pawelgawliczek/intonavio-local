# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql://dev:dev@localhost:5432/intonavio_dev

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API ─────────────────────────────────────────────
PORT=3000
JWT_SECRET=your-jwt-secret-min-32-chars-here
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── Apple Sign In ───────────────────────────────────
APPLE_CLIENT_ID=com.intonavio.app
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ─── Google OAuth ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Cloudflare R2 ──────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=intonavio-stems
R2_PUBLIC_URL=

# ─── StemSplit API ───────────────────────────────────
STEMSPLIT_API_URL=https://stemsplit.io
STEMSPLIT_API_KEY=
STEMSPLIT_WEBHOOK_URL=
STEMSPLIT_WEBHOOK_SECRET=

# ─── Sentry ─────────────────────────────────────────
SENTRY_DSN=

# ─── CORS ─────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001

# ─── Production only (docker-compose.prod.yml) ──────
# POSTGRES_DB=intonavio
# POSTGRES_USER=intonavio
# POSTGRES_PASSWORD=
